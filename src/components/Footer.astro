        <div class="space-y-2 text-sm">
          <a href="https://instagram.com" class="block hover:text-white">Instagram</a>
          <a href="https://facebook.com" class="block hover:text-white">Facebook</a>
          <a href="mailto:hello@temeculawine.com" class="block hover:text-white">Contact</a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 text-xs flex flex-col md:flex-row justify-between gap-4">
      <div>© {new Date().getFullYear()} Temecula Wine Directory. All rights reserved.</div>
      <div>Made with ❤️ in Temecula Valley</div>
    </div>
  </div>
</footer>
