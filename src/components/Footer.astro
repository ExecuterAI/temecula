<footer class="bg-stone-900 text-stone-400 mt-20">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-4 gap-10">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 bg-white/10 rounded-2xl flex items-center justify-center">
            <span class="text-lg">🍷</span>
          </div>
          <span class="font-serif text-2xl text-white tracking-tight">Temecula</span>
        </div>
        <p class="text-sm">Discover the best wineries in Temecula Valley.</p>
      </div>

      <div>
        <div class="font-medium text-white mb-4">Explore</div>
        <div class="space-y-2 text-sm">
          <a href="/wineries" class="block hover:text-white">All Wineries</a>
          <a href="/map" class="block hover:text-white">Wine Map</a>
          <a href="/events" class="block hover:text-white">Events</a>
        </div>
      </div>

      <div>
        <div class="font-medium text-white mb-4">Discover</div>
        <div class="space-y-2 text-sm">
          <a href="/about" class="block hover:text-white">About Temecula</a>
          <a href="/about" class="block hover:text-white">Wine Guide</a>
