      <p class="text-xl text-stone-600 mt-2">Explore all {wineries.length} wineries across the valley</p>
    </div>

    <div class="bg-white border border-stone-200 rounded-3xl overflow-hidden">
      <div id="map" class="w-full h-[620px]"></div>
    </div>

