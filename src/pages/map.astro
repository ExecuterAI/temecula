---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import wineries from '../data/wineries.json';
---

<Layout title="Temecula Wine Map">
  <Navbar />

  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-8">
      <h1 class="text-6xl font-serif tracking-tight">Temecula Wine Map</h1>
      <p class="text-xl text-stone-600 mt-2">Explore all {wineries.length} wineries across the valley</p>
    </div>

    <div class="bg-white border border-stone-200 rounded-3xl overflow-hidden shadow-sm">
      <div id="map" class="w-full h-[650px]"></div>
    </div>

    <div class="mt-4 text-sm text-stone-500 flex items-center gap-2">
      <div class="w-3 h-3 bg-[var(--accent)] rounded-full"></div>
      Click any marker to view winery details
    </div>
  </main>

  <script define:vars={{ wineries }}>
    // Load Leaflet
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(link);

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = () => {
      const map = L.map('map').setView([33.525, -117.02], 11);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
      }).addTo(map);

      // Add all winery markers
      wineries.forEach(winery => {
        if (winery.coordinates) {
          const marker = L.marker([winery.coordinates.lat, winery.coordinates.lng])
            .addTo(map)
            .bindPopup(`
              <div class="min-w-[220px]">
                <strong class="text-lg">${winery.name}</strong><br>
                <span class="text-sm text-stone-600">${winery.address}</span><br><br>
                <a href="/wineries/${winery.slug}" class="text-[var(--accent)] hover:underline">View Details →</a>
              </div>
            `);
        }
      });
    };
    document.head.appendChild(script);
  </script>
</Layout>
