---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import wineries from '../../data/wineries.json';

export function getStaticPaths() {
  return wineries.map(winery => ({
    params: { slug: winery.slug },
    props: { winery }
  }));
}

const { winery } = Astro.props;
---

<Layout title={winery.name}>
  <Navbar />
  
  <!-- Hero Image -->
  <div class="relative h-[420px] w-full">
    <img 
      src={winery.image} 
      alt={winery.name}
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60"></div>
    
    <div class="absolute bottom-0 left-0 right-0">
      <div class="max-w-5xl mx-auto px-6 pb-10">
        <a href="/wineries" class="inline-block text-white/80 hover:text-white mb-4 text-sm">← Back to all wineries</a>
        <h1 class="text-6xl md:text-7xl font-serif text-white tracking-[-2px]">{winery.name}</h1>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-3 text-lg text-white/90">
          <span>{winery.location}</span>
          <span>•</span>
          <span>{winery.price_range}</span>
          <span>•</span>
          <span class="font-medium">{winery.rating} / 5</span>
        </div>
      </div>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-3 gap-10">
      <!-- Main Content -->
      <div class="md:col-span-2">
        <p class="text-2xl leading-tight text-stone-700">{winery.description}</p>

        <!-- Varietals -->
        <div class="mt-10">
          <h3 class="font-serif text-2xl mb-4">Varietals</h3>
          <div class="flex flex-wrap gap-3">
            {winery.varietals.map(v => (
              <span class="px-5 py-2 bg-white border border-stone-200 rounded-full text-sm">{v}</span>
            ))}
          </div>
        </div>

        <!-- Kid Friendly -->
        {winery.kid_friendly && (
          <div class="mt-10">
            <h3 class="font-serif text-2xl mb-3">Families & Children</h3>
            <div class="bg-white border border-stone-200 rounded-2xl p-6">
              <div class="font-medium text-lg">
                {winery.kid_friendly.allowed ? "✓ Children welcome" : "✕ Children not permitted"}
              </div>
              <p class="text-stone-600 mt-2">{winery.kid_friendly.notes}</p>
            </div>
          </div>
        )}

        <!-- Live Music Events -->
        {winery.events && winery.events.length > 0 && (
          <div class="mt-10">
            <h3 class="font-serif text-2xl mb-4">Upcoming Events</h3>
            {winery.events.map(event => (
              <div class="bg-white border border-stone-200 rounded-2xl p-6 mb-4">
                <div class="font-medium text-emerald-600">🎵 {event.type}</div>
                <div class="text-2xl mt-1">{event.band}</div>
                <div class="text-stone-600 mt-1">{event.date} • {event.time}</div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-white border border-stone-200 rounded-2xl p-6">
          <div class="text-sm text-stone-500">Address</div>
          <div class="mt-1 leading-tight">{winery.address}</div>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-6">
          <div class="text-sm text-stone-500">Contact</div>
          <div class="mt-2 space-y-2">
            <a href={winery.website} target="_blank" class="block text-[var(--accent)] hover:underline font-medium">Visit Website →</a>
            <div class="text-stone-700">{winery.phone}</div>
          </div>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-6 text-sm">
          <div class="text-stone-500 mb-1">Pet Policy</div>
          <div class="font-medium">
            {winery.pet_friendly ? "✓ Pet friendly" : "✕ No pets allowed"}
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
