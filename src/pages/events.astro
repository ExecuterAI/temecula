---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import wineries from '../data/wineries.json';

// Collect all events
const allEvents = wineries.flatMap(winery => 
  winery.events?.map(event => ({
    ...event,
    winery: winery.name,
    winerySlug: winery.slug
  })) || []
);
---

<Layout title="Live Music & Events">
  <Navbar />
  
  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-12">
      <h1 class="text-6xl font-serif tracking-tight">Live Music & Events</h1>
      <p class="text-xl text-stone-600 mt-3">Find upcoming performances across Temecula wineries</p>
    </div>

    {allEvents.length > 0 ? (
      <div class="space-y-6">
        {allEvents.map(event => (
          <a href={`/wineries/${event.winerySlug}`} class="block bg-white border border-stone-200 rounded-3xl p-8 hover:shadow-md transition">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <div class="text-emerald-600 font-medium">{event.type}</div>
                <div class="text-3xl font-serif mt-1">{event.band}</div>
                <div class="text-xl text-stone-600 mt-1">{event.winery}</div>
              </div>
              <div class="text-right md:text-left">
                <div class="text-lg font-medium">{event.date}</div>
                <div class="text-stone-600">{event.time}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-stone-600">No upcoming events at the moment. Check back soon.</p>
    )}
  </main>
</Layout>
