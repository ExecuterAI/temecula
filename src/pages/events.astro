---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import wineries from '../data/wineries.json';

const events = wineries
  .filter(w => w.events && w.events.length > 0)
  .flatMap(w => w.events.map(e => ({ ...e, winery: w.name, slug: w.slug })));
---

<Layout title="Upcoming Events">
  <Navbar />

  <main class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-6xl font-serif tracking-tight mb-3">Upcoming Events</h1>
    <p class="text-xl text-stone-600 mb-12">Live music, tastings, and special events at Temecula wineries</p>

    {events.length > 0 ? (
      <div class="space-y-6">
        {events.map(event => (
          <div class="bg-white border border-stone-200 rounded-3xl p-8 flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex-1">
              <div class="text-emerald-600 font-medium">🎵 {event.type}</div>
              <div class="text-3xl font-serif mt-1">{event.band}</div>
              <div class="text-stone-600 mt-1">{event.winery}</div>
            </div>
            <div class="text-right md:text-left">
              <div class="text-xl font-medium">{event.date}</div>
              <div class="text-stone-600">{event.time}</div>
              <a href={`/wineries/${event.slug}`} class="inline-block mt-3 text-[var(--accent)] hover:underline">View Winery →</a>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-stone-600">No upcoming events listed at this time. Check back soon!</p>
    )}
  </main>
</Layout>
