---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import wineries from '../data/wineries.json';
---

<Layout title="All Wineries">
  <Navbar />
  
  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-6xl font-serif tracking-tight">All Wineries</h1>
      <p class="text-xl text-stone-600 mt-3">Explore {wineries.length} estates across Temecula Valley</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-10">
      <select class="px-5 py-2 border border-stone-300 rounded-full text-sm">
        <option>Any Price</option>
        <option>$</option>
        <option>$$</option>
        <option>$$$</option>
      </select>
      
      <select class="px-5 py-2 border border-stone-300 rounded-full text-sm">
        <option>Kid Friendly: Any</option>
        <option>Kid Friendly: Yes</option>
        <option>Kid Friendly: No</option>
      </select>

      <select class="px-5 py-2 border border-stone-300 rounded-full text-sm">
        <option>Live Music: Any</option>
        <option>Has Live Music</option>
      </select>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {wineries.map(winery => (
        <a href={`/wineries/${winery.slug}`} class="group block rounded-3xl overflow-hidden border border-stone-200 bg-white hover:shadow-xl transition">
          <div class="h-60 bg-stone-200"></div>
          <div class="p-6">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-serif text-2xl group-hover:text-[var(--accent)] transition">{winery.name}</h3>
                <p class="text-stone-600">{winery.location} • {winery.price_range}</p>
              </div>
              <div class="text-right">
                <div class="font-medium text-lg">{winery.rating}</div>
              </div>
            </div>
            
            {winery.events && winery.events.length > 0 && (
              <div class="mt-4 text-xs text-emerald-600 font-medium">
                🎵 Live music this weekend
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>
